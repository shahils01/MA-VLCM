Bootstrap: docker
From: nvidia/cuda:12.4.1-cudnn-devel-ubuntu22.04

%post
    # Set environment variables for non-interactive installs
    export DEBIAN_FRONTEND=noninteractive
    export TZ=Etc/UTC

    # Update and install system dependencies
    rm -rf /var/lib/apt/lists/*
    apt-get update
    apt-get install -y --fix-missing \
        python3 \
        python3-pip \
        git \
        ffmpeg \
        wget \
        build-essential \
        libgl1-mesa-glx \
        libglib2.0-0 \
        libsm6 \
        libxext6 \
        libxrender-dev \
        && rm -rf /var/lib/apt/lists/*
    
    # Upgrade pip
    python3 -m pip install --upgrade pip

    # Set CUDA paths (if needed, though base image should handle it)
    export CUDA_HOME=/usr/local/cuda

    # Install Python dependencies
    
    # 1. Install PyTorch with CUDA 12.4 support
    # Remove any pre-installed versions that might conflict
    python3 -m pip uninstall -y torch torchvision torchaudio
    # We explicitly install compatible torch first to match the system CUDA version as closely as possible
    python3 -m pip install torch==2.5.1 torchvision==0.20.1 torchaudio==2.5.1 --extra-index-url https://download.pytorch.org/whl/cu124

    # 2. Install PyG (Torch Geometric) and dependencies manually to ensure compatibility
    # Note: If torch version changes, this URL might need update.
    python3 -m pip install torch-scatter torch-geometric -f https://data.pyg.org/whl/torch-2.5.1+cu124.html
    
    # 3. Install other requirements from a temporary requirements file
    # We list the remaining requirements here to avoid copying the file during build if possible, 
    # but for reproducibility, it's better to install what we know works.
    python3 -m pip install \
        absl-py==2.4.0 \
        accelerate==1.12.0 \
        aiohappyeyeballs==2.6.1 \
        aiohttp==3.13.3 \
        aiosignal==1.4.0 \
        annotated-types==0.7.0 \
        anyio==4.12.1 \
        async-timeout==5.0.1 \
        attrs==25.4.0 \
        bitsandbytes==0.49.1 \
        braceexpand==0.1.7 \
        certifi==2026.1.4 \
        charset-normalizer==3.4.4 \
        click==8.3.1 \
        cloudpickle==3.1.2 \
        contourpy==1.3.2 \
        cycler==0.12.1 \
        decord==0.6.0 \
        etils==1.13.0 \
        exceptiongroup==1.3.1 \
        farama-notifications==0.0.4 \
        filelock==3.20.0 \
        fonttools==4.61.1 \
        frozenlist==1.8.0 \
        fsspec==2025.12.0 \
        gitdb==4.0.12 \
        gitpython==3.1.46 \
        glfw==2.10.0 \
        gym==0.26.2 \
        gym-notices==0.1.0 \
        gymnasium==1.2.3 \
        h11==0.16.0 \
        hf-xet==1.2.0 \
        httpcore==1.0.9 \
        httpx==0.28.1 \
        huggingface-hub==1.3.4 \
        idna==3.11 \
        imageio==2.37.2 \
        imageio-ffmpeg==0.6.0 \
        importlib-resources==6.5.2 \
        jinja2==3.1.6 \
        kiwisolver==1.4.9 \
        llvmlite==0.46.0 \
        markupsafe==2.1.5 \
        matplotlib==3.10.8 \
        mpmath==1.3.0 \
        mujoco==3.4.0 \
        multidict==6.7.1 \
        networkx==3.4.2 \
        noise==1.2.2 \
        numba==0.63.1 \
        numpy==2.2.6 \
        opencv-python \
        packaging==26.0 \
        peft==0.18.1 \
        pillow==12.0.0 \
        platformdirs==4.5.1 \
        propcache==0.4.1 \
        protobuf==6.33.5 \
        psutil==7.2.1 \
        pydantic==2.12.5 \
        pydantic-core==2.41.5 \
        pyopengl==3.1.10 \
        pyparsing==3.3.2 \
        python-dateutil==2.9.0.post0 \
        pyyaml==6.0.3 \
        regex==2026.1.15 \
        requests==2.32.5 \
        safetensors==0.7.0 \
        scikit-learn \
        scipy==1.15.3 \
        sentencepiece==0.2.1 \
        sentry-sdk==2.52.0 \
        setproctitle==1.3.7 \
        shellingham==1.5.4 \
        six==1.17.0 \
        smmap==5.0.2 \
        sympy==1.13.1 \
        tensorboardx==2.6.4 \
        tokenizers==0.22.2 \
        tqdm==4.67.1 \
        transformers==5.1.0 \
        triton==3.1.0 \
        typer-slim==0.21.1 \
        typing-extensions==4.15.0 \
        typing-inspection==0.4.2 \
        urllib3==2.6.3 \
        wandb==0.24.2 \
        webdataset==1.0.2 \
        xxhash==3.6.0 \
        yarl==1.22.0 \
        zipp==3.23.0 \
        einops \
        moviepy \
        lightning \
        jsonlines \
        --extra-index-url https://download.pytorch.org/whl/cu124
    
    # Note: If you have a local requirements.txt, you can copy it in %files and install from there.
    # But embedding key packages here makes the definition more standalone.

    # Clean up caches to reduce container size (prevents mksquashfs OOM)
    python3 -m pip cache purge
    rm -rf /root/.cache/pip /tmp/pip-*
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    export LC_ALL=C
    export LANG=C
    # Ensure nvidia-smi and cuda tools are in path if not already
    export PATH=/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH

%environment
    # Prevent host ~/.local packages from contaminating the container at runtime
    export PYTHONNOUSERSITE=1
    export PATH=/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH

%runscript
    # This script runs when the container is executed
    echo "Container ready. Running command: $@"
    exec "$@"

%labels
    Author MA-VLCM-Team
    Version v1.0
    Description Singularity container for MA-VLCM training